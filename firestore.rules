rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Simple admin check based on a secret field
    function isAdmin() {
      return (request.resource != null && request.resource.data.adminSecret == "Mihriban04") || 
             (resource != null && resource.data.adminSecret == "Mihriban04");
    }

    match /news/{newsId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if true;
    }
  }
}
