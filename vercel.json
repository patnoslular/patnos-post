{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server.ts"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/dist/assets/$1",
      "continue": true
    },
    {
      "source": "/news/(.*)",
      "destination": "/server.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/server.ts"
    }
  ]
}
